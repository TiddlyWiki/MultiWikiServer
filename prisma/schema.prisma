datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client"
  output   = "client"
}

generator json {
  provider  = "prisma-json-types-generator"
  namespace = "PrismaJson"
}

// ---------------------------------------------------------------------------
// Tiddler storage
// ---------------------------------------------------------------------------

model Bag {
  id             String          @id @default(uuid(7))
  name           String          @unique
  created        DateTime        @default(now())
  updated        DateTime        @updatedAt
  description    String
  permissions    BagPermission[]
  tiddlers       Tiddler[]
  recipe_bags    RecipeBag[]
  tiddler_events TiddlerEvent[]

  @@map("bag")
}

// role_id references the auth module's roles table; no FK declared here —
// permission and auth tables are owned by separate modules.
model BagPermission {
  bag_id  String
  role_id String
  level   BagPermissionLevel
  bag     Bag                @relation(fields: [bag_id], references: [id], onDelete: Cascade)

  @@id([bag_id, role_id])
  @@map("bag_permission")
}

model Tiddler {
  bag_id   String
  title    String
  created  DateTime @default(now())
  updated  DateTime @updatedAt
  revision BigInt   @default(0)
  // partition_key String @default("")
  /// [Tiddler_fields]
  fields   Json
  bag      Bag      @relation(fields: [bag_id], references: [id], onDelete: Cascade)

  @@id([bag_id, title])
  @@index([title])
  @@map("tiddler")
}

model TiddlerEvent {
  seq    Int              @id @default(autoincrement())
  bag_id String
  title  String
  type   TiddlerEventType

  bag Bag @relation(fields: [bag_id], references: [id], onDelete: Cascade)

  @@index([bag_id, seq])
  @@map("tiddler_event")
}

enum TiddlerEventType {
  save
  delete
}

model Template {
  id          String               @id @default(uuid(7))
  name        String               @unique
  created     DateTime             @default(now())
  updated     DateTime             @updatedAt
  /// [Template_type]
  type        String
  /// [Template_definition]
  definition  Json
  recipes     Recipe[]
  permissions TemplatePermission[]

  @@map("template")
}

model TemplatePermission {
  template_id String
  role_id     String
  level       TemplatePermissionLevel
  template    Template                @relation(fields: [template_id], references: [id], onDelete: Cascade)

  @@id([template_id, role_id])
  @@map("template_permission")
}

model Recipe {
  id          String             @id @default(uuid(7))
  slug        String             @unique
  created     DateTime           @default(now())
  updated     DateTime           @updatedAt
  template_id String
  /// [Recipe_definition]
  definition  Json
  template    Template           @relation(fields: [template_id], references: [id], onDelete: Restrict)
  recipe_bags RecipeBag[]
  permissions RecipePermission[]
  /// [Recipe_plugins]
  plugins     Json
  compiledAt  DateTime

  @@map("recipe")
}

model RecipePermission {
  recipe_id String
  role_id   String
  level     RecipePermissionLevel
  recipe    Recipe                @relation(fields: [recipe_id], references: [id], onDelete: Cascade)

  @@id([recipe_id, role_id])
  @@map("recipe_permission")
}

model RecipeBag {
  recipe_id   String
  bag_id      String
  priority    Int
  is_writable Boolean
  prefix      String
  recipe      Recipe  @relation(fields: [recipe_id], references: [id], onDelete: Cascade)
  bag         Bag     @relation(fields: [bag_id], references: [id], onDelete: Restrict)

  @@id([recipe_id, bag_id, prefix])
  @@map("recipe_bag")
}

model Settings {
  key     String   @id
  value   String
  updated DateTime @updatedAt

  @@map("settings")
}

// ---------------------------------------------------------------------------
// Auth — managed by the auth module, separate from tiddler storage.
// No FK references cross from auth into tiddler/recipe/bag tables.
// ---------------------------------------------------------------------------

model Roles {
  role_id     String  @id @default(uuid(7))
  role_name   String  @unique()
  description String?
  users       Users[]

  @@map("roles")
}

model Users {
  user_id    String     @id @default(uuid(7))
  username   String     @unique
  email      String     @unique
  password   String
  // sparse index: CREATE UNIQUE INDEX "users_resetCode_key" ON "users"("resetCode") WHERE "resetCode" IS NOT NULL;
  resetCode  String?    @unique
  created_at DateTime   @default(now())
  last_login DateTime?
  sessions   Sessions[]
  roles      Roles[]

  @@map("users")
}

model Sessions {
  session_id    String   @id
  created_at    DateTime @default(now())
  last_accessed DateTime
  session_key   String?
  user_id       String
  user          Users    @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)

  @@map("sessions")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum BagPermissionLevel {
  A_read
  B_write
  C_admin
}

enum RecipePermissionLevel {
  A_read
  B_write
}

enum TemplatePermissionLevel {
  A_read
  B_write
}
