{
  "compilerOptions": {
    "target": "es2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable",
    ],
    "module": "preserve",
    "moduleResolution": "bundler",
    "checkJs": true,
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "alwaysStrict": true,
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": false,
    "allowArbitraryExtensions": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@tiddlywiki",
    "paths": {
      "@/server": [
        "./packages/mws/browser.ts"
      ],
    },
    "skipDefaultLibCheck": false,
    "skipLibCheck": false
  },
  "include": [
    "packages/**/src",
    "prisma/index.ts"
  ],
  "exclude": [
    "packages/admin-react",
    "packages/admin-mdui",
    "packages/mws/src/old-commands",
    "packages/mws/src/old-managers",
    "packages/mws/src/drizzle",
    "packages/mws/src/services/attachments.ts",
    "node_modules",
    "**/node_modules/*"
  ]
}