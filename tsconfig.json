{
  "compilerOptions": {
    "target": "es2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable",
    ],
    "module": "preserve",
    "moduleResolution": "bundler",
    "checkJs": true,
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "alwaysStrict": true,
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": false,
    // "paths": {
    //   "@tiddlywiki/mws-prisma": [
    //     "./prisma/client"
    //   ]
    // },
    // "jsx": "preserve",
    "jsx": "react-jsx",
    "jsxImportSource": "@tiddlywiki",
    "paths": {
      "@/server": [
        "./packages/mws/browser.ts"
      ],
    }
  },
  "include": [
    "packages/**/src",
  ]
}